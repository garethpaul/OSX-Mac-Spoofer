#!/bin/sh
. /etc/rc.common

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
SCRIPT_PATH="$SCRIPT_DIR/SpoofMACAddress.py"

StartService()
{
    ConsoleMessage "Running SpoofMACAddress script."

    if [ "${SPOOF_MAC_ADDRESS_APPLY:-}" != "1" ]; then
        ConsoleMessage "SPOOF_MAC_ADDRESS_APPLY is not set to 1; running dry-run."
        /usr/bin/env python3 "$SCRIPT_PATH" --dry-run
        return $?
    fi

    /usr/bin/env python3 "$SCRIPT_PATH"
}

StopService()
{
    return 0
}

RestartService()
{
    return 0
}

RunService "$1"
